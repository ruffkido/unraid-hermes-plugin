    <span class="hermes-status"><?=htmlspecialchars($v_plugin ?: '—')?></span>
  </div>
  <div class="hermes-row">
    <span class="hermes-label">Hermes Agent</span>
    <span class="hermes-status">
      <?=htmlspecialchars($v_agent ?: '—')?>
      <?php if ($sha_agent): ?><span style="opacity:0.55">· commit <?=htmlspecialchars($sha_agent)?></span><?php endif; ?>
    </span>

  <div class="hermes-paths">
    Logs: <?=htmlspecialchars($WEBUI_LOG)?> · <?=htmlspecialchars($GW_LOG)?>
  </div>
</div>

<!-- =========== Plugin Settings =========== -->
<div class="hermes-section">
  <h3>Plugin Settings <span style="font-weight:normal;opacity:0.6">→ hermes.cfg</span></h3>
  <div class="hermes-row">
    <span class="hermes-label">WebUI port</span>
    <input id="hermes-port" type="number" min="1" max="65535" value="<?=htmlspecialchars($cfg['WEBUI_PORT'])?>" style="width:90px">
  </div>
  <div class="hermes-row">
    <span class="hermes-label">Enable WebUI</span>
    <select id="hermes-webui-enabled">
      <option value="yes"<?=$cfg['WEBUI_ENABLED']==='yes'?' selected':''?>>yes</option>
      <option value="no" <?=$cfg['WEBUI_ENABLED']==='no' ?' selected':''?>>no</option>
    </select>
  </div>
  <div class="hermes-row">
    <span class="hermes-label">Enable Gateway</span>
    <select id="hermes-gw-enabled">
      <option value="yes"<?=$cfg['GATEWAY_ENABLED']==='yes'?' selected':''?>>yes</option>
      <option value="no" <?=$cfg['GATEWAY_ENABLED']==='no' ?' selected':''?>>no</option>
    </select>
  </div>
  <div class="hermes-row">
    <span class="hermes-label">HERMES_HOME path</span>
    <input id="hermes-home-path" type="text" value="<?=htmlspecialchars($cfg['HERMES_HOME_PATH'])?>" style="width:320px" placeholder="/boot/config/plugins/hermes/.hermes">
  </div>
<?php if (!empty($cfg['HERMES_HOME_MIGRATED_FROM']) && is_dir($cfg['HERMES_HOME_MIGRATED_FROM'])): ?>
  <div class="hermes-row" style="background:rgba(255,200,50,0.12);padding:12px 16px;border-radius:8px;margin-top:10px;">
    <span class="hermes-label" style="font-weight:bold">! Migration Complete</span>
    <div style="opacity:0.8;font-size:13px;margin-top:6px;">

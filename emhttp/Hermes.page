<?PHP
/* Hermes plugin — Unraid settings page
 * Lives at /usr/local/emhttp/plugins/hermes/Hermes.page
 * Buttons hit include/action.php via AJAX so we never navigate away
 * from the Unraid menu chrome.
 */

$PLUGIN_DIR = '/boot/config/plugins/hermes';
$CFG        = "$PLUGIN_DIR/hermes.cfg";
$HERMES_HOME = '/boot/config/plugins/hermes/.hermes';
if (is_file($CFG)) {
  foreach (file($CFG, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES) as $line) {
    if (preg_match('/^\s*HERMES_HOME_PATH="?([^"]*)"?\s*$/', $line, $m)) $HERMES_HOME = $m[1];
  }
}
$YAML       = "$HERMES_HOME/config.yaml";
$ENV        = "$HERMES_HOME/.env";
$WEBUI_LOG  = "$HERMES_HOME/webui.log";
$GW_LOG     = "$HERMES_HOME/gateway.log";

function load_cfg($path) {
  $out = ['WEBUI_ENABLED'=>'yes', 'GATEWAY_ENABLED'=>'no', 'WEBUI_PORT'=>'9000', 'HERMES_HOME_PATH'=>'/boot/config/plugins/hermes/.hermes'];
  if (!is_file($path)) return $out;
  foreach (file($path, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES) as $line) {
    if (preg_match('/^\s*([A-Z_]+)="?([^"]*)"?\s*$/', $line, $m)) $out[$m[1]] = $m[2];
  }
  return $out;
}

function service_status($name) {
  $rc = "/etc/rc.d/rc.hermes-$name";
  if (!is_executable($rc)) return ['installed'=>false, 'running'=>false, 'pid'=>null];
  exec("$rc status 2>&1", $out, $code);
  $pid = null;
  foreach ($out as $l) if (preg_match('/PID:\s*(\d+)/', $l, $m)) $pid = (int)$m[1];
  return ['installed'=>true, 'running'=>$code===0, 'pid'=>$pid];
}

function hermes_lan_ip() {
  $ini = @parse_ini_file('/var/local/emhttp/nginx.ini');
  if (!empty($ini['NGINX_LANIP'])) return $ini['NGINX_LANIP'];
  return preg_replace('/:\d+$/', '', $_SERVER['HTTP_HOST'] ?? 'localhost');
}

function hermes_short_sha($name) {
  $sha = trim(@file_get_contents("/usr/local/hermes/$name/.hermes-sha") ?: '');
  return $sha ? substr($sha, 0, 7) : '';
}

function hermes_plugin_version() {
  $out = @shell_exec("plugin version /var/log/plugins/hermes.plg 2>/dev/null");
  return trim($out ?: '');
}

function hermes_agent_version() {
  // hermes --version takes ~1s. Acceptable for a once-on-load render.
  $out = @shell_exec("HERMES_HOME=$HERMES_HOME "
                   . "timeout 5 /usr/local/hermes/venv/bin/hermes --version 2>/dev/null | head -1");
  if (preg_match('/v([\d.]+)\s*\(([\d.\-]+)\)/', (string)$out, $m)) return 'v'.$m[1].' ('.$m[2].')';
  return '';
}

function hermes_webui_version() {
  $f = '/usr/local/hermes/hermes-webui/CHANGELOG.md';
  if (!is_file($f)) return '';
  // First non-Unreleased version heading
  foreach (file($f) as $line) {
    if (preg_match('/^##\s*\[(v[\d.]+)\]/', $line, $m)) return $m[1];
  }
  return '';
}

function hermes_python_version() {
  $out = @shell_exec("/usr/local/hermes/python/bin/python3 --version 2>/dev/null");
  return trim(preg_replace('/^Python\s*/', '', (string)$out));
}

$cfg     = load_cfg($CFG);
$webui   = service_status('webui');
$gateway = service_status('gateway');
$yaml    = is_file($YAML) ? file_get_contents($YAML) : '';
$env     = is_file($ENV)  ? file_get_contents($ENV)  : '';
$host    = hermes_lan_ip();

$v_plugin = hermes_plugin_version();
$v_agent  = hermes_agent_version();
$v_webui  = hermes_webui_version();
$v_python = hermes_python_version();
$sha_agent = hermes_short_sha('hermes-agent');
$sha_webui = hermes_short_sha('hermes-webui');
?>

<style>

  <textarea id="hermes-env" class="hermes-textarea" spellcheck="false" style="min-height:140px"><?=htmlspecialchars($env)?></textarea>
  <div class="hermes-row">
    <button class="hermes-btn" id="hermes-save-env">Save .env</button>
    <button class="hermes-btn" id="hermes-reload-env">Reload from disk</button>
    <span style="opacity:0.6;font-size:12px">Written with mode 0600.</span>
  </div>
</div>

<script>
(function(){
  var ACTION_URL = '/plugins/hermes/include/action.php';
  var HOST       = <?=json_encode($host)?>;
  var $flash     = $('#hermes-flash');

  function flash(msg, isErr) {
    $flash.text(msg)
          .toggleClass('err', !!isErr)
          .stop(true,true).fadeIn(120).delay(2500).fadeOut(400);
  }

  function call(data, cb) {
    return $.post(ACTION_URL, data, null, 'json')
      .done(function(r){
        if (r && r.msg) flash(r.msg, !r.ok);
        if (cb) cb(r);
      })
      .fail(function(xhr){
        flash('Request failed: '+(xhr.statusText||'error'), true);
      });
  }

  function renderStatus(s) {
    var cfg = s.cfg || {};
    var w   = s.webui   || {};
    var g   = s.gateway || {};

    var wHtml = (w.running
      ? '<span class="hermes-dot-on">●</span> Running on :'+cfg.WEBUI_PORT + (w.pid?' (PID '+w.pid+')':'')
      : '<span class="hermes-dot-off">○</span> Stopped'
    );
    var gHtml = (g.running
      ? '<span class="hermes-dot-on">●</span> Running' + (g.pid?' (PID '+g.pid+')':'')
      : '<span class="hermes-dot-off">○</span> '+ (cfg.GATEWAY_ENABLED==='yes' ? 'Stopped' : 'Disabled')
    );
    $('#hermes-webui-status').html(wHtml);
    $('#hermes-gw-status').html(gHtml);
    var $open = $('#hermes-webui-open');
    if (w.running) {
      $open.attr('href','http://'+HOST+':'+cfg.WEBUI_PORT+'/').show();
    } else {
      $open.hide();
    }
  }

  function refreshStatus() {
    call({action:'status'}, function(r){ if (r && r.ok) renderStatus(r); });
  }

  // Service buttons
  $(document).on('click', '.hermes-btn[data-svc]', function(){
    var $btn = $(this).attr('disabled','disabled');
    call({action:'service', svc:$btn.data('svc'), op:$btn.data('op')}, function(){
      refreshStatus();
    }).always(function(){ $btn.removeAttr('disabled'); });
  });

  // Apply plugin settings
  $('#hermes-save-cfg').on('click', function(){
    var $btn = $(this).attr('disabled','disabled');
    call({
      action:'save_cfg',
      WEBUI_ENABLED:   $('#hermes-webui-enabled').val(),
      GATEWAY_ENABLED: $('#hermes-gw-enabled').val(),
      WEBUI_PORT:      $('#hermes-port').val(),
      HERMES_HOME_PATH:$('#hermes-home-path').val()
    }, refreshStatus).always(function(){ $btn.removeAttr('disabled'); });
  });

  $('#hermes-cleanup-migration').on('click', function(){
    if (!confirm('Delete old HERMES_HOME directory? This cannot be undone.')) return;
    var $btn = $(this).attr('disabled','disabled');
    call({action:'cleanup_migration'}, function(r){
      if (r && r.ok) location.reload();
    }).always(function(){ $btn.removeAttr('disabled'); });
  });

  // Save / reload editors
  $('#hermes-save-yaml').on('click', function(){
    var $btn = $(this).attr('disabled','disabled');
    call({action:'save_yaml', content:$('#hermes-yaml').val()})
      .always(function(){ $btn.removeAttr('disabled'); });
  });
  $('#hermes-save-env').on('click', function(){
    var $btn = $(this).attr('disabled','disabled');
    call({action:'save_env',  content:$('#hermes-env').val()})
      .always(function(){ $btn.removeAttr('disabled'); });
  });
  $('#hermes-reload-yaml').on('click', function(){
    call({action:'reload_file', which:'yaml'}, function(r){ if (r && r.ok) $('#hermes-yaml').val(r.content); });
  });
  $('#hermes-reload-env').on('click', function(){
    call({action:'reload_file', which:'env'}, function(r){ if (r && r.ok) $('#hermes-env').val(r.content); });
  });

  // Initial render — re-derive status without a page reload
  refreshStatus();
})();
</script>

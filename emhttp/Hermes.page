    </span>
  </div>
  <div class="hermes-row">
    <span class="hermes-label">Python</span>
    <span class="hermes-status"><?=htmlspecialchars($v_python ?: '—')?></span>
  </div>
</div>

<!-- =========== Service Status =========== -->
<div class="hermes-section">
  <h3>Service Status</h3>

  <div class="hermes-row">
    <span class="hermes-label">WebUI</span>
    <span id="hermes-webui-status" class="hermes-status"></span>
    <a id="hermes-webui-open" class="hermes-btn" target="_blank" style="display:none">Open</a>
